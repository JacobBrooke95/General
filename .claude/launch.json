{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-root",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", ".", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "demo-site",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "demo-site", "-l", "3001"],
      "port": 3001
    },
    {
      "name": "python-http",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
